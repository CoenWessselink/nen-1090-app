{
  "name": "nen1090-frontend-enterprise-rebuild",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/use-source-entry.mjs && node ./node_modules/vite/bin/vite.js",
    "build": "node scripts/use-source-entry.mjs && tsc -b && node ./node_modules/vite/bin/vite.js build",
    "build:pages": "npm run build && node scripts/prepare-release.mjs",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "lint": "npm run typecheck",
    "test": "npm run test:smoke && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed --project=desktop-chromium",
    "test:e2e:auth:live": "PLAYWRIGHT_LIVE_AUTH=1 playwright test tests/e2e/auth-live.spec.ts --project=desktop-chromium",
    "test:smoke": "playwright test tests/e2e/smoke.spec.ts --project=desktop-chromium",
    "test:workflows": "playwright test tests/e2e/projects-crud.spec.ts tests/e2e/project-flow.spec.ts tests/e2e/welds-ce-flow.spec.ts --project=desktop-chromium",
    "test:report": "playwright show-report",
    "test:playwright:install": "playwright install chromium",
    "release:verify": "npm run typecheck && npm run build:pages && npx playwright test --list"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@tanstack/react-query": "^5.66.9",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.1.5",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.20.7",
    "@types/estree": "^1.0.8",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.4.1"
  }
}