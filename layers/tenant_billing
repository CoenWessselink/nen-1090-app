<!doctype html>
<html lang="nl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="../css/theme.css" />
  <title>Abonnement</title>
<link rel="manifest" href="/manifest.webmanifest" />
<meta name="theme-color" content="#0c1830" />
<link rel="apple-touch-icon" href="/icons/icon-192.png" />
</head>
<body data-title="Abonnement">
  <main class="mobile-page-main">
    <section class="mobile-shell-section" style="padding:14px 14px 0;">
      <div class="mobile-section-title">Abonnement</div>
      <div class="mobile-helptext">Mobiele fase 3 shell voor billing status, seats en wijzigingen per tenant.</div>
      <div class="mobile-summary-grid" style="margin-top:10px;">
        <div class="mobile-summary-card"><div class="mobile-summary-label">Seat beheer</div><div class="mobile-summary-value">Live</div></div>
        <div class="mobile-summary-card"><div class="mobile-summary-label">Doel</div><div class="mobile-summary-value">Tenant admin</div></div>
      </div>
    </section>
  <div class="panel-head">
    <div class="panel-tools">
      <button class="btn" id="btnRefresh">Vernieuwen</button>
      <span class="smallmuted" id="hint"></span>
    </div>
    <div class="kbd">Alleen zichtbaar voor role: tenant_admin • Werkt ook als tenant read-only is</div>
  </div>

  <div class="dash-grid">
    <div class="card">
      <h3>Status</h3>
      <div class="sub">Huidige abonnement/billing status</div>

      <div class="kpi2">
        <div class="k"><div class="v" id="kStatus">–</div><div class="l">Status</div></div>
        <div class="k"><div class="v" id="kSeats">–</div><div class="l">Seats</div></div>
        <div class="k"><div class="v" id="kUsers">–</div><div class="l">Actieve users</div></div>
        <div class="k"><div class="v" id="kValid">–</div><div class="l">Geldig tot</div></div>
      </div>

      <div style="margin-top:12px">
        <div class="minirow"><div>Trial tot</div><div id="vTrial">–</div></div>
        <div class="minirow"><div>Billing provider</div><div id="vProvider">–</div></div>
        <div class="minirow"><div>Mollie status</div><div id="vMollieStatus">–</div></div>
        <div class="minirow"><div>Next payment</div><div id="vNextPay">–</div></div>
        <div class="minirow"><div>Pending seats</div><div id="vPending">–</div></div>
      </div>
    </div>

    <div class="card">
      <h3>Seats wijzigen</h3>
      <div class="sub">Upgrade direct • Downgrade gepland op volgende factuurdatum</div>

      <div style="margin-top:12px; display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
        <label class="smallmuted">Nieuwe seats</label>
        <input class="input" id="targetSeats" type="number" min="1" style="width:140px" />
        <button class="btn" id="btnPreview">Preview</button>
        <button class="btn primary" id="btnApply">Toepassen</button>
      </div>

      <div id="previewBox" style="margin-top:12px; border:1px solid var(--border); border-radius:14px; padding:12px; background:linear-gradient(180deg,var(--panel2), #fff);">
        <div class="smallmuted">Preview</div>
        <div style="margin-top:6px" id="previewText">–</div>
      </div>

      <div style="margin-top:12px" class="smallmuted">
        Let op: seats mogen niet lager dan het aantal actieve gebruikers.
      </div>
    </div>
  </div>
  </main>

  <script src="../js/core/routes.js"></script>
  <script src="../js/core/design_system.js"></script>
  <script src="../js/core/store.js"></script>
  <script src="../js/core/ui.js"></script>
  <script src="../js/core/auth_client.js"></script>
  <script src="../js/core/pwa.js"></script>
  <script src="../js/core/shell.js"></script>
  <script src="../js/core/phase3_finalize.js"></script>
  <script src="../js/core/apps_menu.js"></script>
  <script src="../js/tenant_billing.js"></script>
  <script>
    Shell.mount();
  </script>
</body>
</html>
