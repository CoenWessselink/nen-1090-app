<!doctype html>
<html lang="nl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="../css/theme.css" />
  <title>Klantbeheer</title>
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#0c1830" />
  <link rel="apple-touch-icon" href="/icons/icon-192.png" />
  <style>
    .sa-wrap{display:grid;gap:14px;}
    .sa-cards{display:grid;grid-template-columns:repeat(5,minmax(180px,1fr));gap:12px;}
    .sa-card{background:#fff;border:1px solid rgba(15,23,42,.10);border-radius:16px;padding:14px;box-shadow:0 8px 20px rgba(15,23,42,.06);}
    .sa-card-label{font-size:12px;color:#64748b;font-weight:700;text-transform:uppercase;letter-spacing:.04em;}
    .sa-card-value{font-size:28px;font-weight:900;color:#0f172a;margin-top:6px;}
    .sa-card-sub{font-size:12px;color:#64748b;margin-top:4px;}
    .sa-toolbar{display:flex;justify-content:space-between;align-items:flex-end;gap:12px;flex-wrap:wrap;}
    .sa-toolbar-left,.sa-toolbar-right{display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;}
    .sa-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
    .sa-grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;}
    .sa-stack{display:grid;gap:8px;}
    .sa-label{font-size:12px;color:#64748b;font-weight:800;}
    .sa-tabs{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px;}
    .sa-tabpane{display:none;}
    .sa-tabpane.active{display:block;}
    .sa-kpi-line{display:flex;gap:10px;flex-wrap:wrap;margin-top:10px;}
    .sa-chip{display:inline-flex;align-items:center;padding:6px 10px;border-radius:999px;background:#eef2ff;color:#1e3a8a;font-size:12px;font-weight:800;}
    .sa-right{text-align:right;}
    .sa-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;}
    .sa-empty{padding:20px;text-align:center;color:#64748b;}
    .sa-warning{padding:12px 14px;border-radius:14px;background:#fff7ed;border:1px solid #fdba74;color:#9a3412;font-weight:700;}
    .sa-danger{background:#fee2e2 !important;color:#991b1b !important;}
    .sa-success{background:#dcfce7 !important;color:#166534 !important;}
    .sa-muted{font-size:12px;color:#64748b;}
    .sa-modal-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;}
    .sa-modal-grid-3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;}
    .sa-field{display:grid;gap:6px;}
    .sa-field input,.sa-field select,.sa-field textarea{width:100%;}
    .sa-linkline{font-size:12px;color:#64748b;word-break:break-all;}
    .sa-table td .btn{margin-right:6px;}
    @media (max-width:1200px){.sa-cards{grid-template-columns:repeat(3,minmax(180px,1fr));}}
    @media (max-width:860px){.sa-cards,.sa-grid-2,.sa-grid-3,.sa-modal-grid,.sa-modal-grid-3{grid-template-columns:1fr;}}
  </style>
</head>
<body data-title="Klantbeheer (Superadmin)">
  <main class="sa-wrap mobile-page-main">
    <section class="mobile-shell-section" style="padding:14px 14px 0;">
      <div class="mobile-section-title">Klantbeheer</div>
      <div class="mobile-helptext">Mobiele fase 3 shell voor tenants, seats, users, billing en lifecycle beheer.</div>
      <div class="mobile-summary-grid" style="margin-top:10px;">
        <div class="mobile-summary-card"><div class="mobile-summary-label">Weergave</div><div class="mobile-summary-value">Cards</div></div>
        <div class="mobile-summary-card"><div class="mobile-summary-label">Rol</div><div class="mobile-summary-value">Platform</div></div>
      </div>
    </section>
    <section class="card pad">
      <div class="sa-toolbar">
        <div class="sa-toolbar-left">
          <div>
            <div class="sa-label">Zoeken</div>
            <input class="input" id="q" placeholder="Zoek op tenant, status, provider of admin" />
          </div>
          <div>
            <div class="sa-label">Status</div>
            <select class="input" id="statusFilter">
              <option value="all">Alle statussen</option>
              <option value="trial">Trial</option>
              <option value="active">Active</option>
              <option value="suspended">Suspended</option>
              <option value="cancelled">Cancelled</option>
            </select>
          </div>
          <div>
            <div class="sa-label">Billing</div>
            <select class="input" id="billingFilter">
              <option value="all">Alle providers</option>
              <option value="none">none</option>
              <option value="mollie">mollie</option>
            </select>
          </div>
        </div>
        <div class="sa-toolbar-right">
          <button class="btn" id="btnRefresh">Vernieuwen</button>
          <button class="btn" id="btnNewTenant">Nieuwe tenant</button>
          <button class="btn" id="btnExportCsv">Export CSV</button>
        </div>
      </div>
      <div class="sa-muted" style="margin-top:8px;">Volledig klantbeheer voor platform_admin: tenants, seats, gebruikers, billingstatus, audit en lifecycle.</div>
    </section>

    <section class="sa-cards">
      <div class="sa-card"><div class="sa-card-label">Totaal tenants</div><div class="sa-card-value" id="kpiTenants">0</div><div class="sa-card-sub">Alle geregistreerde klanten</div></div>
      <div class="sa-card"><div class="sa-card-label">Active</div><div class="sa-card-value" id="kpiActive">0</div><div class="sa-card-sub">Operationeel actief</div></div>
      <div class="sa-card"><div class="sa-card-label">Trial</div><div class="sa-card-value" id="kpiTrial">0</div><div class="sa-card-sub">Nog in proefperiode</div></div>
      <div class="sa-card"><div class="sa-card-label">Gebruikers</div><div class="sa-card-value" id="kpiUsers">0</div><div class="sa-card-sub">Totaal gekoppelde users</div></div>
      <div class="sa-card"><div class="sa-card-label">Seats</div><div class="sa-card-value" id="kpiSeats">0</div><div class="sa-card-sub">Ingekochte seats totaal</div></div>
    </section>

    <section class="card pad" id="accessDenied" style="display:none;">
      <div class="sa-warning">Deze pagina is alleen bedoeld voor een gebruiker met rol <b>platform_admin</b>. Log in met een platform-beheeraccount om klantbeheer te openen.</div>
    </section>

    <section class="card pad" id="superadminContent">
      <div id="mobileTenantCards" class="mobile-card-list"></div>
      <div class="table-wrap sa-table">
        <table class="mobile-cards">
          <thead>
            <tr>
              <th>Tenant</th>
              <th>Status</th>
              <th>Actief</th>
              <th>Trial tot</th>
              <th>Geldig tot</th>
              <th>Seats</th>
              <th>Users</th>
              <th>Billing</th>
              <th>Actie</th>
            </tr>
          </thead>
          <tbody id="rows">
            <tr><td colspan="9" class="sa-empty">Tenants worden geladen…</td></tr>
          </tbody>
        </table>
      </div>
      <div class="footerbar">
        <div id="count">0 tenants</div>
        <div class="sa-muted">Dubbelklik op een tenant om Tenant 360° te openen.</div>
      </div>
    </section>
  </main>

  <script src="../js/core/routes.js"></script>
  <script src="../js/core/design_system.js"></script>
  <script src="../js/core/store.js"></script>
  <script src="../js/core/ui.js"></script>
  <script src="../js/core/auth_client.js"></script>
  <script src="../js/core/pwa.js"></script>
  <script src="../js/core/shell.js"></script>
  <script src="../js/core/apps_menu.js"></script>
  <script src="../js/core/phase3_finalize.js"></script>
  <script src="../js/superadmin.js"></script>
  <script>
    Shell.mount();
    Phase3Finalize.bindCardsFromRows({
      tbody:'#rows',
      host:'#mobileTenantCards',
      mapRow(tr){
        const cells = tr.querySelectorAll('td');
        const id = tr.getAttribute('data-id') || '';
        const tenant = cells[0]?.textContent?.trim() || 'Tenant';
        const status = cells[1]?.textContent?.trim() || '-';
        const active = cells[2]?.textContent?.trim() || '-';
        const trial = cells[3]?.textContent?.trim() || '-';
        const valid = cells[4]?.textContent?.trim() || '-';
        const seats = cells[5]?.textContent?.trim() || '-';
        const users = cells[6]?.textContent?.trim() || '-';
        const billing = cells[7]?.textContent?.trim() || '-';
        return `<article class="mobile-card">
          <div class="mobile-card-head">
            <div>
              <div class="mobile-card-title">${Phase3Finalize.esc(tenant)}</div>
              <div class="mobile-card-sub">${Phase3Finalize.esc(id)}</div>
            </div>
            <span class="pill">${Phase3Finalize.esc(status)}</span>
          </div>
          <div class="mobile-card-meta">
            <div class="mobile-meta-item"><div class="mobile-meta-label">Actief</div><div class="mobile-meta-value">${Phase3Finalize.esc(active)}</div></div>
            <div class="mobile-meta-item"><div class="mobile-meta-label">Trial tot</div><div class="mobile-meta-value">${Phase3Finalize.esc(trial)}</div></div>
            <div class="mobile-meta-item"><div class="mobile-meta-label">Geldig tot</div><div class="mobile-meta-value">${Phase3Finalize.esc(valid)}</div></div>
            <div class="mobile-meta-item"><div class="mobile-meta-label">Billing</div><div class="mobile-meta-value">${Phase3Finalize.esc(billing)}</div></div>
            <div class="mobile-meta-item"><div class="mobile-meta-label">Seats</div><div class="mobile-meta-value">${Phase3Finalize.esc(seats)}</div></div>
            <div class="mobile-meta-item"><div class="mobile-meta-label">Users</div><div class="mobile-meta-value">${Phase3Finalize.esc(users)}</div></div>
          </div>
          <div class="mobile-card-actions">
            <button class="btn" type="button" data-open-id="${Phase3Finalize.esc(id)}">Open tenant</button>
          </div>
        </article>`;
      }
    });
  </script>
</body>
</html>
