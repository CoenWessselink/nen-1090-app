<!doctype html>
<html lang="nl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Projecten</title>
  <script>window.__API_BASE_URL__ = window.__API_BASE_URL__ || localStorage.getItem("API_BASE_URL") || "/api";</script>
  <link rel="stylesheet" href="../css/theme.css" />
  <meta name="theme-color" content="#0c1830" />
  <style>
    .projects-page{display:grid;gap:18px;}
    .projects-hero{display:flex;justify-content:space-between;align-items:flex-start;gap:18px;flex-wrap:wrap;}
    .projects-title{margin:0;font-size:44px;line-height:1;letter-spacing:-.03em;color:#0f172a;}
    .projects-sub{margin:8px 0 0;color:#64748b;font-size:15px;}
    .projects-toolbar,.projects-tabs{display:flex;gap:12px;flex-wrap:wrap;align-items:center;}
    .projects-toolbar .input{min-width:280px;}
    .projects-tabs .btn{background:#fff;}
    .projects-tabs .btn.active{color:#2563eb;border-color:#bfdbfe;box-shadow:inset 0 -2px 0 #2563eb;}
    .projects-surface{padding:22px;}
    .projects-surface-header{display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:18px;}
    .projects-table{overflow:auto;}
    .projects-table table{width:100%;border-collapse:separate;border-spacing:0;min-width:980px;}
    .projects-table td:first-child,.projects-table th:first-child{padding-left:28px;}
    .projects-table td:last-child,.projects-table th:last-child{padding-right:28px;}
    .status-pill{display:inline-flex;align-items:center;justify-content:center;padding:8px 14px;border-radius:999px;font-size:13px;font-weight:800;min-width:110px;}
    .status-pill.in-controle{background:#dbeafe;color:#1d4ed8;}
    .status-pill.conform{background:#dcfce7;color:#166534;}
    .status-pill.afgekeurd{background:#fee2e2;color:#b91c1c;}
    .status-pill.locked{background:#e5e7eb;color:#334155;}
    .projects-actions{display:flex;gap:8px;align-items:center;justify-content:flex-end;}
    .projects-pagination{display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;padding-top:18px;color:#64748b;font-size:14px;}
    .projects-mobile-cards{display:none;gap:12px;}
    .project-mobile-card{background:#fff;border:1px solid #e5e7eb;border-radius:18px;padding:16px;box-shadow:0 10px 24px rgba(15,23,42,.05);}
    .project-mobile-top{display:flex;justify-content:space-between;align-items:flex-start;gap:10px;}
    .project-mobile-code{font-size:24px;font-weight:900;color:#0f172a;letter-spacing:-.03em;}
    .project-mobile-name{font-size:18px;font-weight:800;color:#0f172a;margin-top:2px;}
    .project-mobile-client{font-size:14px;color:#64748b;margin-top:4px;}
    .project-mobile-meta{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;margin-top:14px;}
    .project-mobile-meta div{background:#f8fafc;border:1px solid #e2e8f0;border-radius:14px;padding:10px 12px;}
    .project-mobile-meta strong{display:block;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#64748b;margin-bottom:4px;}
    .project-mobile-actions{display:flex;gap:8px;margin-top:14px;}
    .empty-state{padding:48px 12px;text-align:center;color:#64748b;}
    .empty-state strong{display:block;color:#0f172a;font-size:18px;margin-bottom:8px;}
    @media (max-width:720px){
      .projects-hero{gap:14px;}
      .projects-title{font-size:34px;}
      .projects-sub{display:none;}
      .projects-toolbar{width:100%;display:grid;grid-template-columns:1fr 1fr;}
      .projects-toolbar .input{grid-column:1 / -1;min-width:0;width:100%;}
      .projects-tabs{overflow:auto;flex-wrap:nowrap;padding-bottom:2px;}
      .projects-tabs .btn{flex:0 0 auto;}
      .projects-surface{padding:16px;}
      .projects-table,.projects-pagination{display:none;}
      .projects-mobile-cards{display:grid;}
    }
  </style>
</head>
<body data-title="Projecten">
  <main class="mobile-page-main">
    <section class="projects-page">
      <div class="projects-hero">
        <div>
          <h1 class="projects-title">Projecten</h1>
          <p class="projects-sub">Bekijk, filter en beheer alle projecten vanuit één overzicht.</p>
        </div>
        <div class="projects-toolbar">
          <input id="projectSearch" class="input" type="search" placeholder="Zoeken..." />
          <button id="btnNieuw" class="btn cws-btn-primary">+ Nieuw project</button>
          <button id="btnKolommen" class="btn">Kolommen</button>
          <button id="btnExport" class="btn">Export</button>
        </div>
      </div>

      <div class="projects-tabs">
        <button class="btn active" data-filter="all">Alle</button>
        <button class="btn" data-filter="in_controle">In controle</button>
        <button class="btn" data-filter="conform">Conform</button>
        <button class="btn" data-filter="afgekeurd">Afgekeurd</button>
        <button class="btn" data-filter="locked">Locked</button>
      </div>

      <section class="projects-surface cws-card">
        <div class="projects-surface-header">
          <div class="projects-sub" id="projectsCount">0 projecten</div>
        </div>

        <div id="mobileProjectCards" class="projects-mobile-cards"></div>

        <div class="projects-table mobile-table-wrap">
          <table class="mobile-cards">
            <thead>
              <tr>
                <th>Projectnummer</th>
                <th>Projectnaam</th>
                <th>Opdrachtgever</th>
                <th>Executieklasse</th>
                <th>Acceptatieklasse</th>
                <th>Status</th>
                <th>Laatst gewijzigd</th>
                <th>Actie</th>
              </tr>
            </thead>
            <tbody id="projectsTbody">
              <tr class="empty-row"><td colspan="8">Projecten worden geladen…</td></tr>
            </tbody>
          </table>
        </div>

        <div class="projects-pagination">
          <div id="projectsPaginationInfo">0 projecten</div>
          <div>
            <button class="btn" type="button" disabled aria-label="Vorige pagina">‹</button>
            <span style="padding:0 8px;">1</span>
            <button class="btn" type="button" disabled aria-label="Volgende pagina">›</button>
          </div>
        </div>
      </section>
    </section>
  </main>

  <script src="../js/core/routes.js"></script>
  <script src="../js/core/design_system.js"></script>
  <script src="../js/core/store.js"></script>
  <script src="../js/core/permissions.js"></script>
  <script src="../js/core/ui.js"></script>
  <script src="../js/core/apps_menu.js"></script>
  <script src="../js/core/export.js"></script>
  <script src="../js/core/auth_client.js"></script>
  <script src="../js/core/pwa.js"></script>
  <script src="../js/core/shell.js"></script>
  <script>
    (function(){
      const state = { allProjects: [], filteredProjects: [], filter: 'all', search: '' };
      function esc(v){ return String(v ?? '').replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;').replaceAll('"','&quot;').replaceAll("'", '&#039;'); }
      function getToken(){ return localStorage.getItem('nen1090.auth.access') || localStorage.getItem('auth_token') || ''; }
      function getApiBaseUrl(){ const base = localStorage.getItem('nen1090.api.baseUrl') || localStorage.getItem('API_BASE_URL') || window.__API_BASE_URL__ || '/api'; return String(base || '').replace(/\/+$/,''); }
      async function apiFetch(path, options){
        const token = getToken(); const baseUrl = getApiBaseUrl();
        const headers = new Headers((options && options.headers) || {}); headers.set('Accept', 'application/json'); if(token){ headers.set('Authorization', 'Bearer ' + token); }
        if(options && options.body && !headers.has('Content-Type')) headers.set('Content-Type', 'application/json');
        const res = await fetch(baseUrl + path, Object.assign({}, options || {}, { headers }));
        let json = null; let text = '';
        const ct = res.headers.get('content-type') || '';
        if(ct.includes('application/json')) json = await res.json().catch(()=>null); else text = await res.text().catch(()=>'');
        if(!res.ok){ const detail = (json && (json.detail || json.message)) || text || ('HTTP ' + res.status); const err = new Error(detail); err.status = res.status; err.payload = json; throw err; }
        return json;
      }
      function formatDate(v){ if(!v) return ''; const d = new Date(v); if(Number.isNaN(d.getTime())) return String(v); return d.toLocaleDateString('nl-NL', { day:'2-digit', month:'short', year:'numeric' }); }
      function mapStatusLabel(v){ const s = String(v || '').toLowerCase(); if(s === 'in_controle') return 'In controle'; if(s === 'conform') return 'Conform'; if(s === 'afgekeurd') return 'Afgekeurd'; if(s === 'locked') return 'Locked'; return v || ''; }
      function mapStatusClass(v){ const s = String(v || '').toLowerCase(); if(s === 'in_controle') return 'in-controle'; if(s === 'conform') return 'conform'; if(s === 'afgekeurd') return 'afgekeurd'; if(s === 'locked') return 'locked'; return 'in-controle'; }
      function toFrontendProject(project){ return { id: project.id, nummer: project.code || '', naam: project.name || '', opdrachtgever: project.client_name || '', executieklasse: project.execution_class || '', acceptatieklasse: project.acceptance_class || '', status: project.locked ? 'locked' : (project.status || 'in_controle'), locked: !!project.locked, laatstGewijzigd: project.updated_at || project.created_at || '' }; }
      function syncProjectsIntoCwsStore(projects){ try{ if(!window.CWS || !window.CWS.getState || !window.CWS.setState) return; const st = window.CWS.getState(); st.projects.byId = {}; st.projects.order = []; projects.forEach((p)=>{ st.projects.byId[p.id] = { id:p.id, nummer:p.nummer, naam:p.naam, opdrachtgever:p.opdrachtgever, exc:p.executieklasse, acceptatieklasse:p.acceptatieklasse, status:p.status, locked:p.locked, laatstGewijzigd:p.laatstGewijzigd }; st.projects.order.push(p.id); }); if(!st.ui.activeProjectId && st.projects.order[0]) st.ui.activeProjectId = st.projects.order[0]; window.CWS.setState(st); }catch(err){ console.error('Sync CWS store mislukt:', err); } }
      function getVisibleProjects(){ const q = state.search.trim().toLowerCase(); return state.allProjects.filter((p)=>{ if(state.filter === 'locked' && !p.locked) return false; if(state.filter !== 'all' && state.filter !== 'locked' && p.status !== state.filter) return false; if(!q) return true; const hay = [p.nummer, p.naam, p.opdrachtgever, p.executieklasse, p.acceptatieklasse, p.status].join(' ').toLowerCase(); return hay.includes(q); }); }
      function updateCounter(){ const text = `${state.filteredProjects.length} project${state.filteredProjects.length === 1 ? '' : 'en'}`; document.getElementById('projectsCount').textContent = text; document.getElementById('projectsPaginationInfo').textContent = text; }
      function renderMobileCards(projects){ const wrap = document.getElementById('mobileProjectCards'); if(!wrap) return; if(!projects.length){ wrap.innerHTML = `<div class="empty-state"><strong>Geen projecten gevonden</strong>Pas de zoekopdracht of filter aan.</div>`; return; } wrap.innerHTML = projects.map((project)=>`
        <article class="project-mobile-card">
          <div class="project-mobile-top">
            <div>
              <div class="project-mobile-code">${esc(project.nummer || '-')}</div>
              <div class="project-mobile-name">${esc(project.naam || 'Naamloos project')}</div>
              <div class="project-mobile-client">${esc(project.opdrachtgever || '-')}</div>
            </div>
            <span class="status-pill ${esc(mapStatusClass(project.status))}">${esc(mapStatusLabel(project.status))}</span>
          </div>
          <div class="project-mobile-meta">
            <div><strong>Executieklasse</strong>${esc(project.executieklasse || '-')}</div>
            <div><strong>Acceptatieklasse</strong>${esc(project.acceptatieklasse || '-')}</div>
          </div>
          <div class="project-mobile-actions">
            <button class="btn" data-action="edit" data-id="${esc(project.id)}">Bewerken</button>
            <button class="btn" data-action="delete" data-id="${esc(project.id)}">Verwijderen</button>
          </div>
        </article>`).join(''); }
      function renderTable(projects){ const tbody = document.getElementById('projectsTbody'); if(!projects.length){ tbody.innerHTML = `<tr><td colspan="8"><div class="empty-state"><strong>Geen projecten gevonden</strong>Pas de zoekopdracht of filter aan.</div></td></tr>`; return; } tbody.innerHTML = projects.map((project)=>`
          <tr data-project-id="${esc(project.id)}">
            <td><strong>${esc(project.nummer || '-')}</strong></td>
            <td>${esc(project.naam || '')}</td>
            <td>${esc(project.opdrachtgever || '')}</td>
            <td>${esc(project.executieklasse || '')}</td>
            <td>${esc(project.acceptatieklasse || '')}</td>
            <td><span class="status-pill ${esc(mapStatusClass(project.status))}">${esc(mapStatusLabel(project.status))}</span></td>
            <td>${esc(formatDate(project.laatstGewijzigd))}</td>
            <td><div class="projects-actions"><button class="btn" data-action="edit" data-id="${esc(project.id)}">Bewerken</button><button class="btn" data-action="delete" data-id="${esc(project.id)}">Verwijderen</button></div></td>
          </tr>`).join(''); }
      function render(){ state.filteredProjects = getVisibleProjects(); updateCounter(); renderTable(state.filteredProjects); renderMobileCards(state.filteredProjects); }
      async function loadProjects(){ const tbody = document.getElementById('projectsTbody'); try{ const response = await apiFetch('/api/v1/projects'); const projects = Array.isArray(response) ? response : Array.isArray(response.items) ? response.items : []; state.allProjects = projects.map(toFrontendProject); syncProjectsIntoCwsStore(state.allProjects); render(); }catch(error){ console.error(error); tbody.innerHTML = `<tr><td colspan="8"><div class="empty-state"><strong>Projecten konden niet worden geladen</strong>${esc(error.message || 'Onbekende fout')}</div></td></tr>`; document.getElementById('mobileProjectCards').innerHTML = `<div class="empty-state"><strong>Projecten konden niet worden geladen</strong>${esc(error.message || 'Onbekende fout')}</div>`; updateCounter(); } }
      async function saveProject(projectId, payload){ if(projectId){ await apiFetch(`/api/v1/projects/${projectId}`, { method:'PUT', body:JSON.stringify(payload) }); UI.toast('Project bijgewerkt'); } else { await apiFetch('/api/v1/projects', { method:'POST', body:JSON.stringify(payload) }); UI.toast('Project aangemaakt'); } await loadProjects(); }
      async function deleteProject(project){ if(!confirm(`Project ${project.nummer} verwijderen?`)) return; await apiFetch(`/api/v1/projects/${project.id}`, { method:'DELETE' }); UI.toast('Project verwijderd'); await loadProjects(); }
      function openProjectModal(project){ const current = project || { nummer:'', naam:'', opdrachtgever:'', executieklasse:'', acceptatieklasse:'', status:'in_controle' }; UI.modalForm({ title: project ? 'Project bewerken' : 'Nieuw project', submitLabel: project ? 'Opslaan' : 'Aanmaken', values:{ code:current.nummer, name:current.naam, client_name:current.opdrachtgever, execution_class:current.executieklasse, acceptance_class:current.acceptatieklasse, status:current.status }, fields:[ { key:'code', label:'Projectnummer', type:'text' }, { key:'name', label:'Projectnaam', type:'text' }, { key:'client_name', label:'Opdrachtgever', type:'text' }, { key:'execution_class', label:'Executieklasse', type:'text' }, { key:'acceptance_class', label:'Acceptatieklasse', type:'text' }, { key:'status', label:'Status', type:'select', options:[ {value:'in_controle',label:'In controle'}, {value:'conform',label:'Conform'}, {value:'afgekeurd',label:'Afgekeurd'}, {value:'locked',label:'Locked'} ] } ], onSubmit: async (values)=>{ const payload = { code: values.code, name: values.name, client_name: values.client_name, execution_class: values.execution_class, acceptance_class: values.acceptance_class, status: values.status }; await saveProject(project ? project.id : null, payload); return true; } }); }
      function bindEvents(){ document.getElementById('projectSearch').addEventListener('input', (e)=>{ state.search = e.target.value || ''; render(); }); document.querySelectorAll('[data-filter]').forEach((btn)=>{ btn.addEventListener('click', ()=>{ state.filter = btn.getAttribute('data-filter'); document.querySelectorAll('[data-filter]').forEach((el)=>el.classList.toggle('active', el === btn)); render(); }); }); document.getElementById('btnNieuw').addEventListener('click', ()=>openProjectModal(null)); document.getElementById('btnExport').addEventListener('click', ()=>{ try{ Export.toCsv('projecten.csv', state.filteredProjects); }catch(error){ console.error(error); UI.toast('Export mislukt'); } }); document.getElementById('btnKolommen').addEventListener('click', ()=>UI.toast('Kolommenbeheer volgt in volgende stap.')); document.getElementById('projectsTbody').addEventListener('click', async (e)=>{ const btn = e.target.closest('[data-action]'); if(!btn) return; const id = btn.getAttribute('data-id'); const project = state.allProjects.find((p)=>String(p.id) === String(id)); if(!project) return; const action = btn.getAttribute('data-action'); if(action === 'edit') openProjectModal(project); else if(action === 'delete') await deleteProject(project); }); document.getElementById('mobileProjectCards').addEventListener('click', async (e)=>{ const btn = e.target.closest('[data-action]'); if(!btn) return; const id = btn.getAttribute('data-id'); const project = state.allProjects.find((p)=>String(p.id) === String(id)); if(!project) return; const action = btn.getAttribute('data-action'); if(action === 'edit') openProjectModal(project); else if(action === 'delete') await deleteProject(project); }); }
      async function bootstrap(){ try{ Shell.mount(); }catch(_){} bindEvents(); await loadProjects(); }
      bootstrap();
    })();
  </script>
</body>
</html>